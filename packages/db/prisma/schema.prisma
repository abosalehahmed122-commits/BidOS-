// Bid OS — Prisma schema
// Multi-tenant: every tenant-scoped model carries `workspaceId` and is filtered
// by the `forWorkspace()` client extension (see src/tenant.ts). Postgres RLS is
// added as a second line of defense in prisma/sql/rls.sql.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum Role {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum PaymentProvider {
  NONE
  MOYASAR
  TAP
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum TenderSource {
  ETIMAD
  MANUAL
  OTHER
}

enum TenderStatus {
  NEW
  UNDER_REVIEW
  DECIDED_BID
  DECIDED_NO_BID
  SUBMITTED
  WON
  LOST
  ARCHIVED
}

enum DocumentKind {
  BOOKLET // كراسة الشروط
  ATTACHMENT
  ADDENDUM // ملحق
  OTHER
}

enum RunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum PipelineStage {
  PREPARING
  EXTRACTING
  EVALUATING
  SCORING
  FINALIZING
  COMPLETED
}

enum RequirementCategory {
  TECHNICAL
  FINANCIAL
  LEGAL
  CERTIFICATION
  GUARANTEE
  LOCAL_CONTENT // المحتوى المحلي
  HSE
  OTHER
}

enum DeadlineType {
  INQUIRIES // آخر موعد للاستفسارات
  BID_OPENING // فتح المظاريف
  SUBMISSION // التسليم
  SITE_VISIT // زيارة الموقع
  AWARD // الترسية
  OTHER
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskCategory {
  PENALTY // غرامات
  INTELLECTUAL_PROPERTY // ملكية فكرية
  PAYMENT_TERMS // شروط الدفع
  CONTRADICTION // تعارض داخل الكراسة
  SCOPE_CREEP
  GUARANTEE
  INSURANCE
  OTHER
}

enum GapType {
  MISSING_DOCUMENT
  MISSING_CERTIFICATION
  CAPABILITY_GAP
  FINANCIAL_GAP
  CLASSIFICATION_GAP // التصنيف
  OTHER
}

enum BidRecommendation {
  BID
  NO_BID
  REVIEW
}

enum ProposalStatus {
  DRAFT
  IN_REVIEW
  FINAL
}

enum ProposalSectionType {
  COVER
  EXECUTIVE_SUMMARY
  METHODOLOGY
  TIMELINE
  TEAM
  EXPERIENCE
  PRICING_BOQ // جدول الكميات والأسعار
  COMPLIANCE
  APPENDIX
  OTHER
}

enum CompanyDocumentType {
  COMMERCIAL_REGISTRATION // السجل التجاري
  ZAKAT_CERTIFICATE // شهادة الزكاة
  GOSI_CERTIFICATE // التأمينات الاجتماعية
  CONTRACTOR_CLASSIFICATION // تصنيف المقاولين
  VAT_CERTIFICATE
  CHAMBER_MEMBERSHIP // الغرفة التجارية
  COMPANY_PROFILE
  CV
  PREVIOUS_WORK // سابقة الأعمال
  BANK_GUARANTEE
  OTHER
}

enum DecisionType {
  BID
  NO_BID
  DEFER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum NotificationType {
  DEADLINE_APPROACHING
  DOCUMENT_EXPIRING
  ANALYSIS_COMPLETE
  TASK_ASSIGNED
  MEMBER_INVITED
  DECISION_RECORDED
  OTHER
}

enum UsageMetric {
  AI_PAGES
  TENDERS_ANALYZED
  PROPOSALS_GENERATED
  STORAGE_BYTES
  SEATS
}

// ============================================================================
// Identity & tenancy
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  emailVerified DateTime?
  image         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships Membership[]
  sessions    Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Tenant root. Everything below is scoped by `workspaceId`.
model Workspace {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  logoUrl    String?
  brandColor String   @default("#0B1F3A")
  vatNumber  String?
  crNumber   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships     Membership[]
  subscription    Subscription?
  invoices        Invoice[]
  payments        Payment[]
  usageMeters     UsageMeter[]
  tenders         Tender[]
  companyDocs     CompanyDocument[]
}

model Membership {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        Role     @default(VIEWER)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

// ============================================================================
// Billing
// ============================================================================

model Plan {
  id           String   @id @default(cuid())
  code         String   @unique // trial | basic | pro | enterprise
  name         String
  priceMonthly Int      @default(0) // halalas (SAR * 100)
  currency     String   @default("SAR")
  limits       Json // { tendersPerMonth, aiPagesPerMonth, seats, storageBytes, proposalsPerMonth }
  features     Json     @default("[]")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(cuid())
  workspaceId        String             @unique
  planId             String
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id])

  @@index([planId])
}

model Invoice {
  id              String        @id @default(cuid())
  workspaceId     String
  number          String        @unique // ZATCA-compliant sequential number
  status          InvoiceStatus @default(DRAFT)
  subtotal        Int // halalas
  vatRate         Float         @default(0.15)
  vatAmount       Int
  total           Int
  currency        String        @default("SAR")
  sellerName      String
  sellerVatNumber String
  buyerName       String
  qrPayload       String? // ZATCA TLV base64 (Phase 1 generation)
  issuedAt        DateTime      @default(now())
  dueAt           DateTime?
  createdAt       DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@index([workspaceId])
}

model Payment {
  id          String          @id @default(cuid())
  workspaceId String
  invoiceId   String?
  provider    PaymentProvider @default(NONE)
  providerRef String?
  amount      Int
  currency    String          @default("SAR")
  status      PaymentStatus   @default(PENDING)
  paidAt      DateTime?
  createdAt   DateTime        @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id])

  @@index([workspaceId])
  @@index([invoiceId])
}

model UsageMeter {
  id          String      @id @default(cuid())
  workspaceId String
  metric      UsageMetric
  period      String // YYYY-MM
  value       Int         @default(0)
  updatedAt   DateTime    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, metric, period])
  @@index([workspaceId])
}

// ============================================================================
// Tenders & analysis pipeline
// ============================================================================

model Tender {
  id                 String       @id @default(cuid())
  workspaceId        String
  title              String
  referenceNumber    String? // رقم المنافسة في اعتماد
  agency             String? // الجهة الحكومية
  source             TenderSource @default(MANUAL)
  sourceUrl          String?
  status             TenderStatus @default(NEW)
  submissionDeadline DateTime?
  estimatedValue     Int? // halalas
  currency           String       @default("SAR")
  createdById        String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  documents      TenderDocument[]
  extractionRuns ExtractionRun[]
  requirements   Requirement[]
  attachments    Attachment[]
  deadlines      Deadline[]
  riskItems      RiskItem[]
  gapItems       GapItem[]
  bidScore       BidScore?
  proposals      Proposal[]
  decisionLogs   DecisionLog[]
  tasks          Task[]
  comments       Comment[]

  @@index([workspaceId])
  @@index([workspaceId, status])
}

model TenderDocument {
  id           String       @id @default(cuid())
  workspaceId  String
  tenderId     String
  kind         DocumentKind @default(BOOKLET)
  fileName     String
  mimeType     String
  sizeBytes    Int
  storageKey   String // key in the Storage port (disk / S3)
  pageCount    Int?
  uploadedById String
  createdAt    DateTime     @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([tenderId])
}

/// One run of the analysis pipeline over a document. Outputs are versioned and
/// a single run can be re-executed.
model ExtractionRun {
  id               String        @id @default(cuid())
  workspaceId      String
  tenderId         String
  documentId       String?
  version          Int           @default(1)
  status           RunStatus     @default(QUEUED)
  stage            PipelineStage @default(PREPARING)
  progress         Int           @default(0) // 0..100
  provider         String        @default("mock")
  model            String?
  promptTokens     Int           @default(0)
  completionTokens Int           @default(0)
  costCents        Int           @default(0)
  result           Json? // raw validated ExtractionResult (source of truth)
  error            String?
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime      @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([tenderId])
}

model Requirement {
  id              String              @id @default(cuid())
  workspaceId     String
  tenderId        String
  extractionRunId String?
  category        RequirementCategory @default(OTHER)
  title           String
  description     String?
  mandatory       Boolean             @default(true)
  sourcePage      Int? // citation: page in the booklet
  sourceQuote     String? // citation: the original Arabic text
  confidence      Float               @default(0) // 0..1
  createdAt       DateTime            @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([tenderId])
}

/// المرفقات المطلوبة في العرض — documents the bidder must submit.
model Attachment {
  id                       String   @id @default(cuid())
  workspaceId              String
  tenderId                 String
  extractionRunId          String?
  name                     String
  description              String?
  mandatory                Boolean  @default(true)
  sourcePage               Int?
  confidence               Float    @default(0)
  satisfiedByCompanyDocId  String? // auto-matched from the company library
  createdAt                DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([tenderId])
}

model Deadline {
  id          String       @id @default(cuid())
  workspaceId String
  tenderId    String
  type        DeadlineType @default(OTHER)
  title       String
  dueAt       DateTime
  sourcePage  Int?
  confidence  Float        @default(0)
  notifiedAt  DateTime?
  createdAt   DateTime     @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([tenderId])
  @@index([dueAt])
}

model RiskItem {
  id              String       @id @default(cuid())
  workspaceId     String
  tenderId        String
  extractionRunId String?
  severity        RiskSeverity @default(MEDIUM)
  category        RiskCategory @default(OTHER)
  title           String
  description     String?
  sourcePage      Int?
  sourceQuote     String?
  confidence      Float        @default(0)
  createdAt       DateTime     @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([tenderId])
}

model GapItem {
  id                  String   @id @default(cuid())
  workspaceId         String
  tenderId            String
  type                GapType  @default(OTHER)
  title               String
  description         String?
  blocking            Boolean  @default(false)
  relatedRequirementId String?
  confidence          Float    @default(0)
  createdAt           DateTime @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([tenderId])
}

model BidScore {
  id              String            @id @default(cuid())
  workspaceId     String
  tenderId        String            @unique
  extractionRunId String?
  totalScore      Int // 0..100
  recommendation  BidRecommendation @default(REVIEW)
  factors         Json // [{ key, label, weight, score, rationale }]
  rationale       String // overall written rationale (Arabic)
  computedAt      DateTime          @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ============================================================================
// Proposals
// ============================================================================

model Proposal {
  id          String         @id @default(cuid())
  workspaceId String
  tenderId    String
  title       String
  status      ProposalStatus @default(DRAFT)
  version     Int            @default(1)
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tender   Tender            @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  sections ProposalSection[]

  @@index([workspaceId])
  @@index([tenderId])
}

model ProposalSection {
  id          String              @id @default(cuid())
  workspaceId String
  proposalId  String
  type        ProposalSectionType @default(OTHER)
  title       String
  order       Int                 @default(0)
  contentMd   String?
  contentJson Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([proposalId])
}

// ============================================================================
// Company document library
// ============================================================================

model CompanyDocument {
  id           String              @id @default(cuid())
  workspaceId  String
  type         CompanyDocumentType @default(OTHER)
  name         String
  fileName     String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  issueDate    DateTime?
  expiryDate   DateTime? // تنبيه قبل انتهاء الصلاحية
  notes        String?
  uploadedById String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([expiryDate])
}

// ============================================================================
// Collaboration, decisions, audit
// ============================================================================

/// Append-only decision journal (لماذا دخلنا/لم ندخل).
model DecisionLog {
  id            String       @id @default(cuid())
  workspaceId   String
  tenderId      String
  decision      DecisionType
  reason        String
  bidScoreSnapshot Json?
  decidedById   String
  decidedAt     DateTime     @default(now())

  tender Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([tenderId])
}

model Task {
  id          String     @id @default(cuid())
  workspaceId String
  tenderId    String?
  title       String
  description String?
  status      TaskStatus @default(TODO)
  assigneeId  String?
  dueAt       DateTime?
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tender   Tender?   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@index([workspaceId])
  @@index([tenderId])
  @@index([assigneeId])
}

model Comment {
  id          String   @id @default(cuid())
  workspaceId String
  tenderId    String?
  taskId      String?
  body        String
  authorId    String
  createdAt   DateTime @default(now())

  tender Tender? @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([tenderId])
}

model Notification {
  id          String           @id @default(cuid())
  workspaceId String
  userId      String
  type        NotificationType @default(OTHER)
  title       String
  body        String?
  data        Json?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([workspaceId])
  @@index([userId, readAt])
}

/// Append-only audit trail for sensitive operations.
model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String?
  actorId     String?
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  ip          String?
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([entity, entityId])
}
