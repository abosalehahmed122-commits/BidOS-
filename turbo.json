{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": ["NODE_ENV", "DATABASE_URL", "AI_PROVIDER", "ANTHROPIC_API_KEY"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "@bid-os/db#generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "@bid-os/db#generate": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["@bid-os/db#generate"]
    },
    "test": {
      "dependsOn": ["@bid-os/db#generate"]
    }
  }
}
