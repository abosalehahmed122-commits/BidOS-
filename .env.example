# =========================================================================
# Bid OS — Environment variables (copy to .env and fill in)
# Nothing here is required to BUILD the project. Cloud services can be wired
# in later; local dev defaults to disk storage + the mock AI provider.
# =========================================================================

# --- Core ---------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Database (PostgreSQL) ----------------------------------------------
# Local (docker-compose): postgresql://bidos:bidos@localhost:5432/bidos?schema=public
# Cloud (Neon/Supabase): use the pooled connection string.
DATABASE_URL="postgresql://bidos:bidos@localhost:5432/bidos?schema=public"
# Direct (non-pooled) URL for migrations on serverless Postgres providers.
DIRECT_DATABASE_URL=""

# --- Platform admin -----------------------------------------------------
# Comma-separated emails granted the cross-tenant Super-Admin panel (/admin),
# in addition to any user with isSuperAdmin=true in the DB.
SUPER_ADMIN_EMAILS=""

# --- Auth ---------------------------------------------------------------
# 32+ char random secret used to sign session JWTs. Generate: openssl rand -base64 32
AUTH_SECRET="dev-only-insecure-secret-change-me-in-production-please"
SESSION_TTL_DAYS=30

# --- AI provider (provider-agnostic) ------------------------------------
# mock = deterministic offline provider (no key needed, default for dev/tests)
# anthropic = Claude (vision) — requires ANTHROPIC_API_KEY
AI_PROVIDER=mock
ANTHROPIC_API_KEY=""
AI_EXTRACTION_MODEL=claude-sonnet-4-6
AI_REASONING_MODEL=claude-opus-4-8

# --- Object storage (S3-compatible) -------------------------------------
# disk = LocalDiskStorage adapter (writes to ./.storage, default for dev)
# s3   = any S3-compatible bucket (Cloudflare R2 / AWS S3 / MinIO)
STORAGE_DRIVER=disk
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET="bid-os"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""

# --- Queue (BullMQ / Redis) ---------------------------------------------
# inline = run jobs in-process (default for dev, no Redis needed)
# redis  = use a real Redis instance + a separate worker process
QUEUE_DRIVER=inline
REDIS_URL="redis://localhost:6379"

# --- Email (Resend or compatible) ---------------------------------------
# console = log emails to stdout (default for dev)
EMAIL_DRIVER=console
RESEND_API_KEY=""
EMAIL_FROM="Bid OS <no-reply@bid-os.local>"

# --- SMS / OTP (phone verification — anti-abuse) ------------------------
# console = log the code to stdout (default). unifonic = real delivery.
SMS_DRIVER=console
UNIFONIC_APP_SID=""
SMS_SENDER="BidOS"

# --- Payments (DEFERRED — abstraction only, no provider wired yet) -------
PAYMENT_PROVIDER=none
# MOYASAR_API_KEY=""
# TAP_API_KEY=""

# --- ZATCA e-invoicing (Phase 1: compliant generation only) -------------
ZATCA_SELLER_NAME="شركتك"
ZATCA_SELLER_VAT_NUMBER="300000000000003"
